import requests
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
from google.colab import userdata

# Input .
locatie = input('Locatie: ')


# API gegevens.
api_code = userdata.get('api_weer') #veilige api code
api_url = f'http://api.openweathermap.org/data/2.5/forecast?q={locatie}&units=metric&appid={api_code}'

# Ophalen gegevens van OpenWeatherMap API.
resultaat = requests.get(api_url)

#Check of de verbinding met de api succesvol is.
if resultaat.status_code == 200:
    # Omzetten van Json naar pandas DF
    df_weer = pd.json_normalize(resultaat.json()['list'])

    # Omzetten van unix naar datums
    df_weer['utc_datetime'] = pd.to_datetime(df_weer['dt_txt'], utc=True)
    df_weer.set_index('utc_datetime', inplace=True)
    # Temperatuur strings omzetten naar integers
    df_weer['main.temp'] = pd.to_numeric(df_weer['main.temp'], errors='coerce')

    # Grafiek plotten
    grafiek = plt.plot(df_weer.index,df_weer['main.temp'])
    #grafiek = ax.plot(df_weer['utc_datetime'], df_weer['main.temp'], marker='o', linestyle='-')

    # Assen van de grafiek formatteren
    ax = plt.gca()
    ax.set_ylabel('temperatuur [°]')
    ax.set_xlabel('datum')
    ax.tick_params(axis='x', rotation=75)
    ax.set_title(f'Temperatuur in {locatie}')


    print(grafiek)
    plt.show()
else:
    #Verbinding is niet gelukt :( fout melding geven en app afsluiten.
    print(f'Weer bericht niet gevonden voor {locatie}')
    exit()

print(resultaat.json())
